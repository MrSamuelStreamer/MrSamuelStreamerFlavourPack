<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Parent recipe -->
  <RecipeDef Abstract="True" Name="MSSFP_Vending_Bill">
    <jobString>Using vending machine.</jobString>
    <workAmount>600</workAmount>
    <formingTicks>60000</formingTicks> <!-- 1h = 2500 ticks, 24h = 60000 ticks -->
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <soundWorking>MechGestatorCycle_Initiating</soundWorking>
    <recipeUsers>
      <li>MSSFP_Vending_Machine</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Silver</li>
          </thingDefs>
        </filter>
        <count>100</count> <!-- silver is a small-volume material so 100 = 1000 -->
      </li>
    </ingredients>
    <researchPrerequisite>Machining</researchPrerequisite>
    <workSkill>Crafting</workSkill>
  </RecipeDef>

  <!-- example recipe. add anything from above parent recipe to amend it in the child recipe, use <ingredients Inherit="False"> if changing ingredient

