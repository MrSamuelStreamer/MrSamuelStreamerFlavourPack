<?xml version="1.0" encoding="UTF-8" ?>
<Patch>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/GeneDef[defName="BS_Incorporate"]</xpath>
        <value>
            <enablesNeeds><li>MSS_Need_GeneStealer</li></enablesNeeds>
        </value>
    </Operation>

    <Operation Class="PatchOperationConditional">
        <xpath>Defs/StatDef[defName="SM_BodySizeMultiplier"]/parts</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/StatDef[defName="SM_BodySizeMultiplier"]</xpath>
            <value>
                <parts />
            </value>
        </nomatch>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/StatDef[defName="SM_BodySizeMultiplier"]/parts</xpath>
        <value>
            <li Class="MSSFP.BS.StatPart_BodyOffset" />
        </value>
    </Operation>


    <Operation Class="PatchOperationReplace">
        <xpath>Defs/AbilityDef[defName="BS_Incorporate_Abillity"]/cooldownTicksRange</xpath>
        <value>
            <cooldownTicksRange>60000</cooldownTicksRange>
        </value>
    </Operation>

    <!-- Tag MSSFP_Raven race with the sapience hediff so RaceMorpher / generator
         attaches it when a sapient version is generated. -->
    <Operation Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="MSSFP_Raven"]/modExtensions</xpath>
        <nomatch Class="PatchOperationAdd">
            <xpath>Defs/ThingDef[defName="MSSFP_Raven"]</xpath>
            <value>
                <modExtensions />
            </value>
        </nomatch>
    </Operation>
    <Operation Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="MSSFP_Raven"]/modExtensions</xpath>
        <value>
            <li Class="BigAndSmall.RaceExtension">
                <raceHediff>HL_MSSFP_Raven_RaceHediff</raceHediff>
            </li>
        </value>
    </Operation>
</Patch>
