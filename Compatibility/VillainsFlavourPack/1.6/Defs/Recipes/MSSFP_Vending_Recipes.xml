<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Parent recipe -->
  <RecipeDef Abstract="True" Name="MSSFP_Vending_Bill">
    <jobString>Using vending machine.</jobString>
    <workAmount>600</workAmount>
    <formingTicks>60000</formingTicks> <!-- 1h = 2500 ticks, 24h = 60000 ticks -->
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <soundWorking>MechGestatorCycle_Initiating</soundWorking>
    <recipeUsers>
      <li>MSSFP_Vending_Machine</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Silver</li>
          </thingDefs>
        </filter>
        <count>100</count> <!-- silver is a small-volume material so 100 = 1000 -->
      </li>
    </ingredients>
    <researchPrerequisite>Machining</researchPrerequisite>
    <workSkill>Crafting</workSkill>
  </RecipeDef>

  <!-- example recipe. add anything from above parent recipe to amend it in the child recipe, use <ingredients Inherit="False"> if changing ingredient

  <RecipeDef ParentName="MSSFP_Vending_Bill">
    <defName>MSSFP_Vending_Pull</defName>
    <label>produced item</label>
    <description>description</description>
    <products>
      <itemdefname>1</itemdefname>
    </products>
  </RecipeDef>

  -->

  <RecipeDef ParentName="MSSFP_Vending_Bill">
    <defName>MSSFP_Vending_Neutroamine</defName>
    <label>vend emergency neutroamine</label>
    <description>Emergency Neutroamine. For when you're in dire need.</description>
    <displayPriority>1</displayPriority>
    <formingTicks>20000</formingTicks> <!-- 8 hours -->
    <products>
      <Neutroamine>2</Neutroamine>
    </products>
  </RecipeDef>

  <RecipeDef ParentName="MSSFP_Vending_Bill">
    <defName>MSSFP_Vending_Survivalpack</defName>
    <label>vend emergency survival meal</label>
    <description>Emergency Survival pack. For when you're truly desperate.</description>
    <displayPriority>2</displayPriority>
    <formingTicks>15000</formingTicks> <!-- 6 hours -->
    <products>
      <MealSurvivalPack>1</MealSurvivalPack>
    </products>
  </RecipeDef>

  <RecipeDef ParentName="MSSFP_Vending_Bill" MayRequire="lizzy.milkablehivequeenslurm">
    <defName>MSS_Vend_hivequeenslurm</defName>
    <label>vend slurm</label>
    <description>Delicious slurm!</description>
    <products>
      <Insectoid_Milk>1</Insectoid_Milk>
    </products>
    <formingTicks>2500</formingTicks>
    <ingredients Inherit="False">
      <li>
        <filter>
          <thingDefs>
            <li>Silver</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
  </RecipeDef>
  <displayPriority>10</displayPriority>
  
</Defs>