<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!--
        Attach MSSFP.StatParts.StatPart_PonderingOrbAstroNav to vanilla StatDefOf.GravshipRange.
        The StatPart adds a flat tile bonus to max launch range when a powered, persona-loaded
        Pondering Orb sits on the engine's substructure.

        PatchOperationSequence + PatchOperationConditional is used because vanilla StatDef XML
        omits the <parts> element when a stat has no parts. A plain PatchOperationAdd would
        silently no-op there. We first ensure <parts> exists, then insert our <li>. The C#-side
        BootCheck logs a warning if this attachment fails (e.g. another mod later replaces the
        <parts> list).
    -->
    <Operation Class="PatchOperationSequence">
        <operations>
            <li Class="PatchOperationConditional">
                <xpath>Defs/StatDef[defName="GravshipRange"]/parts</xpath>
                <nomatch Class="PatchOperationAdd">
                    <xpath>Defs/StatDef[defName="GravshipRange"]</xpath>
                    <value>
                        <parts/>
                    </value>
                </nomatch>
            </li>
            <li Class="PatchOperationAdd">
                <xpath>Defs/StatDef[defName="GravshipRange"]/parts</xpath>
                <value>
                    <li Class="MSSFP.StatParts.StatPart_PonderingOrbAstroNav">
                        <bonusTiles>5</bonusTiles>
                    </li>
                </value>
            </li>
        </operations>
    </Operation>
</Patch>
