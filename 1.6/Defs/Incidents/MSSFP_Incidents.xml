<?xml version="1.0" encoding="UTF-8"?>
<Defs>
    <IncidentDef>
        <defName>MSSFP_RaidEnemy_Skylantern</defName>
        <label>enemy raid</label>
        <category>Special</category>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_RaidEnemySkylantern</workerClass>
        <baseChance>0</baseChance>
        <!-- given by a special storyteller comp -->
        <requireColonistsPresent>True</requireColonistsPresent>
        <pointsScaleable>true</pointsScaleable>
        <tale>Raid</tale>
        <ignoreRecentSelectionWeighting>true</ignoreRecentSelectionWeighting>
    </IncidentDef>
    <TaleDef>
        <defName>MSSFP_Lovers_Retreat_Tale</defName>
        <label>lovers retreat</label>
        <taleClass>Tale_DoublePawn</taleClass>
        <type>Volatile</type>
        <baseInterest>5</baseInterest>
        <firstPawnSymbol>LOVERA</firstPawnSymbol>
        <secondPawnSymbol>LOVERB</secondPawnSymbol>
        <usableForArt>true</usableForArt>
        <rulePack>
            <rulesStrings>
                <li>tale_noun->[LOVERA_nameDef] whisked [LOVERB_nameDef] away for a romantic retreat</li>
                <li>tale_noun->[LOVERA_nameDef] lead [LOVERB_nameDef] out of the colony for some personal time</li>
                <li>tale_noun->[LOVERB_nameDef] caught [LOVERB_nameDef]'s eye with a cheeky grin before quickly sneaking off to a secluded location.</li>
            </rulesStrings>
        </rulePack>
    </TaleDef>
    <JobDef>
        <defName>MSSFP_GoToThen</defName>
        <driverClass>MSSFP.Jobs.JobDriver_GoToThen</driverClass>
        <reportString>moving.</reportString>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
        <carryThingAfterJob>true</carryThingAfterJob>
        <dropThingBeforeJob>false</dropThingBeforeJob>
    </JobDef>
    <IncidentDef>
        <defName>MSSFP_Lovers_Retreat</defName>
        <label>lovers retreat</label>
        <category>Misc</category>
        <baseChance>5</baseChance>
        <earliestDay>14</earliestDay>
        <minRefireDays>45</minRefireDays>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_LoversRetreat</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
    </IncidentDef>
    <LetterDef>
        <defName>MSSFP_HireMercenariesOffer</defName>
        <label>mercenary hiring offer</label>
        <letterClass>MSSFP.Letters.ChoiceLetter_HireMercenaries</letterClass>
        <color>(0.7, 0.7, 0.7)</color>
        <arriveSound>LetterArrive</arriveSound>
    </LetterDef>
    <IncidentDef>
        <defName>MSSFP_Hire_Mercenaries</defName>
        <label>hire mercenaries</label>
        <category>Misc</category>
        <baseChance>3</baseChance>
        <earliestDay>30</earliestDay>
        <minRefireDays>60</minRefireDays>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_HireMercenaries</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
        <letterDef>MSSFP_HireMercenariesOffer</letterDef>
    </IncidentDef>

    <!-- Template Wanderer Join: a random PawnTemplateDef character wanders in and joins -->
    <IncidentDef>
        <defName>MSSFP_WandererJoin_Template</defName>
        <label>a familiar face arrives</label>
        <category>Misc</category>
        <baseChance>1</baseChance>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_WandererJoin_Template</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
        <letterLabel>A familiar face</letterLabel>
        <letterText>{PAWN_nameDef} has wandered into your colony. Having heard of your group and seeking a new purpose, {PAWN_pronoun} has decided to join your cause.\n\n{PAWN_nameDef} will now be one of your colonists.</letterText>
    </IncidentDef>

    <!-- Codex Punch: Codex teleports in, punches a colonist, teleports out -->
    <JobDef>
        <defName>MSSFP_SkipPunchAndLeave</defName>
        <driverClass>MSSFP.Jobs.JobDriver_SkipPunchAndLeave</driverClass>
        <reportString>preparing to punch TargetA.</reportString>
        <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
        <neverFleeFromEnemies>true</neverFleeFromEnemies>
    </JobDef>
    <IncidentDef>
        <defName>MSSFP_CodexPunch</defName>
        <label>a failed god-puncher</label>
        <category>Misc</category>
        <baseChance>0.5</baseChance>
        <earliestDay>60</earliestDay>
        <minRefireDays>120</minRefireDays>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_CodexPunch</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
    </IncidentDef>

    <!--
        IED Pod Raid: hostile drop pods land scattered across the map. Each pod
        scatters vanilla IED traps in a radius around its landing cell. Plain
        IncidentWorker (NOT IncidentWorker_Raid) — no pawns, just traps.
    -->
    <!--
        Raven Creepjoiner: an unsettlingly sapient raven (MSSFP_Raven) wanders in
        and joins as colonist. Sapience hediff applies aptitudes (Int=20, Social=10) +
        TooSmart trait via Big&Small Sapient Animals framework. Aura hediff buffs
        colonists within 6 tiles. Sapience hediff is gated to RedMattis.BetterPrerequisites
        being active (lives in compatibility folder); aura hediffs are unconditional.
    -->
    <IncidentDef>
        <defName>MSSFP_RavenCreepJoinerJoin</defName>
        <label>an unsettling visitor</label>
        <category>Misc</category>
        <baseChance>0.5</baseChance>
        <earliestDay>10</earliestDay>
        <minRefireDays>120</minRefireDays>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_RavenCreepJoinerJoin</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
        <letterLabel>An unsettling visitor</letterLabel>
        <letterText>A black bird perches at the edge of camp. Too still. Watching. When you approach, it tilts its head and — you'd swear — nods.\n\n{PAWN_nameDef} has decided your colony is interesting enough to stay.</letterText>
    </IncidentDef>

    <IncidentDef>
        <defName>MSSFP_RaidEnemy_IEDPods</defName>
        <label>IED pod scatter</label>
        <category>ThreatBig</category>
        <baseChance>1</baseChance>
        <minThreatPoints>250</minThreatPoints>
        <earliestDay>14</earliestDay>
        <minRefireDays>30</minRefireDays>
        <targetTags>
            <li>Map_PlayerHome</li>
        </targetTags>
        <workerClass>MSSFP.Incidents.IncidentWorker_IEDPodRaid</workerClass>
        <requireColonistsPresent>true</requireColonistsPresent>
        <pointsScaleable>true</pointsScaleable>
    </IncidentDef>
</Defs>
