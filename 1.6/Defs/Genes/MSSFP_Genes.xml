<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <HediffDef>
        <defName>MSSFP_TouchedGrass</defName>
        <label>touched grass</label>
        <description>This person has touched grass</description>
        <hediffClass>HediffWithComps</hediffClass>
        <defaultLabelColor>(0.7, 1.0, 0.7)</defaultLabelColor>
        <isBad>false</isBad>
        <makesSickThought>false</makesSickThought>
        <scenarioCanAdd>false</scenarioCanAdd>
        <maxSeverity>1</maxSeverity>
        <minSeverity>0</minSeverity>
        <initialSeverity>0.01</initialSeverity>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDayRange>0.75</severityPerDayRange>
                <showHoursToRecover>true</showHoursToRecover>
            </li>
        </comps>
        <stages>
            <li>
                <label>minor</label>
                <statFactors>
                    <MoveSpeed>1.1</MoveSpeed>
                </statFactors>
                <statOffsets>
                    <MentalBreakThreshold>-0.1</MentalBreakThreshold>
                    <GlobalLearningFactor>0.1</GlobalLearningFactor>
                    <ImmunityGainSpeed>0.1</ImmunityGainSpeed>
                    <CarryingCapacity>0.1</CarryingCapacity>
                    <PainShockThreshold>0.1</PainShockThreshold>
                    <FilthRate>-0.1</FilthRate>
                    <NegotiationAbility>0.1</NegotiationAbility>
                    <PawnBeauty>0.1</PawnBeauty>
                    <TradePriceImprovement>0.1</TradePriceImprovement>
                    <SocialImpact>0.1</SocialImpact>
                </statOffsets>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.05</offset>
                    </li>
                    <li>
                        <capacity>Talking</capacity>
                        <offset>0.05</offset>
                    </li>
                    <li>
                        <capacity>Breathing</capacity>
                        <offset>0.05</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>moderate</label>
                <minSeverity>0.20</minSeverity>
                <statFactors>
                    <MoveSpeed>1.1</MoveSpeed>
                </statFactors>
                <statOffsets>
                    <MentalBreakThreshold>-0.2</MentalBreakThreshold>
                    <GlobalLearningFactor>0.2</GlobalLearningFactor>
                    <ImmunityGainSpeed>0.2</ImmunityGainSpeed>
                    <CarryingCapacity>0.2</CarryingCapacity>
                    <PainShockThreshold>0.2</PainShockThreshold>
                    <FilthRate>-0.2</FilthRate>
                    <NegotiationAbility>0.2</NegotiationAbility>
                    <PawnBeauty>0.2</PawnBeauty>
                    <TradePriceImprovement>0.2</TradePriceImprovement>
                    <SocialImpact>0.2</SocialImpact>
                </statOffsets>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.10</offset>
                    </li>
                    <li>
                        <capacity>Talking</capacity>
                        <offset>0.10</offset>
                    </li>
                    <li>
                        <capacity>Breathing</capacity>
                        <offset>0.10</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <label>maximum</label>
                <minSeverity>0.50</minSeverity>
                <statFactors>
                    <MoveSpeed>1.1</MoveSpeed>
                </statFactors>
                <statOffsets>
                    <MentalBreakThreshold>-0.3</MentalBreakThreshold>
                    <GlobalLearningFactor>0.3</GlobalLearningFactor>
                    <ImmunityGainSpeed>0.3</ImmunityGainSpeed>
                    <CarryingCapacity>0.3</CarryingCapacity>
                    <PainShockThreshold>0.3</PainShockThreshold>
                    <FilthRate>-0.3</FilthRate>
                    <NegotiationAbility>0.3</NegotiationAbility>
                    <PawnBeauty>0.3</PawnBeauty>
                    <TradePriceImprovement>0.3</TradePriceImprovement>
                    <SocialImpact>0.3</SocialImpact>
                </statOffsets>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>0.15</offset>
                    </li>
                    <li>
                        <capacity>Talking</capacity>
                        <offset>0.15</offset>
                    </li>
                    <li>
                        <capacity>Breathing</capacity>
                        <offset>0.15</offset>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>
    <GeneDef>
        <defName>MSSFP_TouchGrass</defName>
        <label>Grass Toucher</label>
        <description>Spending time in nature can temporarily boost the social skills of the carrier</description>
        <iconPath>UI/Icons/Genes/MSSFP_GrassToucher</iconPath>
        <geneClass>MSSFP.Genes.Gene_GrassToucher</geneClass>
        <descriptionHyperlinks>
            <HediffDef>MSSFP_TouchedGrass</HediffDef>
        </descriptionHyperlinks>
    </GeneDef>
    <GeneDef>
        <defName>MSSFP_Illiterate</defName>
        <label>illiterate</label>
        <description>The carrier of this gene is incapable of reading.</description>
        <iconPath>UI/Icons/Genes/MSSFP_Illiterate</iconPath>
    </GeneDef>


    <GeneDef>
        <defName>MSS_VoidsEmbrace</defName>
        <label>void's embrace</label>
        <description>The void's tendrils claim the carrier, dragging them back from the precipice of death. But each rebirth is a harrowing journey through the void's desolate expanse, leaving the soul scarred and the mind emptied.</description>
        <geneClass>MSSFP.Genes.Gene_VoidsEmbrace</geneClass>
        <iconPath>UI/Icons/Genes/Gene_Deathless</iconPath>
        <displayCategory>Archite</displayCategory>
        <marketValueFactor>2</marketValueFactor>
        <biostatCpx>7</biostatCpx>
        <biostatArc>1</biostatArc>
        <customEffectDescriptions>
            <li>Can only die from destruction of brain.</li>
            <li>On each near-death, skills degrade by 0–5 levels.</li>
            <li>On each near-death, the void imprints 2–4 random curse traits (rarely more), replacing the previous set.</li>
        </customEffectDescriptions>
        <symbolPack>
            <wholeNameSymbols>
                <li><symbol>immortal</symbol></li>
            </wholeNameSymbols>
            <prefixSymbols>
                <li><symbol>void</symbol></li>
                <li><symbol>curse</symbol></li>
                <li><symbol>scorne</symbol></li>
            </prefixSymbols>
            <suffixSymbols>
                <li><symbol>hanted</symbol></li>
            </suffixSymbols>
        </symbolPack>
    </GeneDef>

    <AbilityDef ParentName="AbilityTouchBase">
        <defName>MSSFP_IntegratorReimplantXenogerm</defName>
        <label>integrate genes</label>
        <description>Implant this person's xenogenes into a subject. The implanter loses all xenogenes permanently and becomes a baseliner xenotype. If this person's genes are currently regrowing, they will implant their xenogerm and die in the process.</description>
        <iconPath>UI/Icons/Genes/Gene_XenogermReimplanter</iconPath>
        <warmupStartSound>ReimplantXenogerm_Cast</warmupStartSound>
        <warmupEffecter>Implant_Xenogerm</warmupEffecter>

        <displayOrder>501</displayOrder>
        <hostile>false</hostile>
        <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
        <verbProperties>
            <verbClass>Verb_CastAbilityTouch</verbClass>
            <drawAimPie>false</drawAimPie>
            <range>-1</range>
            <warmupTime>4</warmupTime>
            <stunTargetOnCastStart>true</stunTargetOnCastStart>
            <targetParams>
                <canTargetAnimals>false</canTargetAnimals>
                <canTargetSelf>false</canTargetSelf>
                <canTargetBuildings>false</canTargetBuildings>
                <canTargetMechs>false</canTargetMechs>
            </targetParams>
        </verbProperties>
        <comps>
            <li Class="MSSFP.Comps.CompProperties_AbilityIntegratorReimplantXenogerm" />
        </comps>
    </AbilityDef>

    <GeneDef>
        <defName>MSSFP_GeneIntegrator</defName>
        <label>gene integrator</label>
        <labelShortAdj>integrator</labelShortAdj>
        <description>Carriers of this gene can implant a copy of their xenogerm into another person. They permanently lose all of their xenogenes, any in-progress gene regrowth is cancelled, and they become a baseliner xenotype. If they implant while their genes are regrowing, they will die.</description>
        <iconPath>UI/Icons/Genes/Gene_XenogermReimplanter</iconPath>
        <displayCategory>Archite</displayCategory>
        <abilities>
            <li>MSSFP_IntegratorReimplantXenogerm</li>
        </abilities>
        <descriptionHyperlinks>
            <AbilityDef>MSSFP_IntegratorReimplantXenogerm</AbilityDef>
        </descriptionHyperlinks>
        <biostatCpx>3</biostatCpx>
        <biostatArc>1</biostatArc>
    </GeneDef>
</Defs>
